# Variáveis de ambiente do projeto.
# Copie este arquivo para .env.local e preencha conforme necessário.

# Google Tag Manager — ID do container (formato GTM-XXXXXXX).
# Opcional: sem este valor, o GTM não é carregado e os eventos
# permanecem inertes no dataLayer. Deve ser definido em produção.
NEXT_PUBLIC_GTM_ID=

# Resend — chave da API para envio de e-mail transacional.
# https://resend.com/api-keys
RESEND_API_KEY=

# Endereço remetente dos e-mails de lead. Padrão: onboarding@resend.dev
# (funciona sem domínio verificado, mas só consegue enviar para o e-mail
# da conta Resend). Em produção, troque para leads@wvarq.com após
# verificar o domínio no painel do Resend.
LEAD_FROM_EMAIL=

# E-mail destino para notificações de novos leads do formulário.
# Em testes pode apontar para um e-mail pessoal; em produção, para o
# endereço oficial do escritório.
LEAD_NOTIFICATION_EMAIL=

# URL do Google Apps Script Web App que grava os leads na planilha.
# Formato: https://script.google.com/macros/s/.../exec
LEADS_SHEET_WEBHOOK_URL=
